# ── Django Core ────────────────────────────────────────────────
SECRET_KEY=django-insecure-generate-a-new-one-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: comma-separated, overrides default http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
# Optional (recommended for token verification)
SUPABASE_ANON_KEY=your-supabase-anon-key
# ── Threat Detection APIs ───────────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key
GOOGLE_SAFE_BROWSING_KEY=your-google-safe-browsing-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
IPQS_API_KEY=your-ipqs-api-key
GNEWS_API_KEY=your-gnews-api-key


OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openrouter/free
GEMINI_API_KEY=your-gemini-api-key

# ── SMS / Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1-your-phone-number

# ── Redis Cache ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Blockchain (Phase 2) ────────────────────────────────────────
POLYGON_RPC_URL=
WALLET_PRIVATE_KEY=
